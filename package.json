{
  "name": "duality-godhood-server",
  "version": "1.0.0",
  "description": "Local server for Duality of Godhood fan site",
  "main": "server.js",
  "dependencies": {
    "axios": "^1.6.2",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2"
  },
  "scripts": {
    "build": "echo 'No build step required'",
    "start": "node server.js",
    "dev:server": "nodemon server.js",
    "dev:sync": "browser-sync start --proxy 'localhost:3000' --files '*.html, *.css, *.js, images/**/*' --no-notify",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:sync\""
  },
  "devDependencies": {
    "browser-sync": "^3.0.4",
    "concurrently": "^10.0.3",
    "nodemon": "^3.1.14"
  }
}
